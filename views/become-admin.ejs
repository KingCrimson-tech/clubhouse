<!-- filepath: views/become-admin.ejs -->
<%- include('partials/header', { title: 'Become Admin' }) %>

<h1>👑 Become an Admin</h1>

<div style="background: #fff3cd; padding: 20px; border-radius: 5px; margin-bottom: 30px; border-left: 4px solid #ffc107;">
  <p><strong>⚠️ Admin privileges include:</strong></p>
  <ul style="margin-top: 10px; margin-left: 20px;">
    <li>Delete any message on the board</li>
    <li>Moderate the community</li>
    <li>Full administrative access</li>
  </ul>
</div>

<form method="POST" action="/become-admin">
  <div class="form-group">
    <label for="admin_secret">Enter Admin Secret Code</label>
    <input type="password" id="admin_secret" name="admin_secret" placeholder="Hint: admin123" required>
  </div>

  <button type="submit">Become Admin</button>
</form>

<%- include('partials/footer') %>