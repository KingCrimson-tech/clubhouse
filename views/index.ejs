<!-- filepath: views/index.ejs -->
<%- include('partials/header', { title: 'Clubhouse - Home' }) %>

<h1 style="margin-bottom: 30px;">📬 Message Board</h1>

<% if (!user) { %>
  <div style="background: #fff3cd; padding: 20px; border-radius: 5px; margin-bottom: 30px; border-left: 4px solid #ffc107;">
    <strong>👋 Welcome, Guest!</strong>
    <p style="margin-top: 10px;">You can view messages, but to see who wrote them and post your own, please <a href="/signup">sign up</a> or <a href="/login">login</a>.</p>
  </div>
<% } %>

<% if (messages && messages.length > 0) { %>
  <% messages.forEach(message => { %>
    <div class="message-card">
      <h3 class="message-title"><%= message.title %></h3>
      <p class="message-content"><%= message.content %></p>
      
      <% if (user && user.is_member) { %>
        <div class="message-meta">
          Posted by <strong><%= message.first_name %> <%= message.last_name %></strong>
          on <%= new Date(message.created_at).toLocaleDateString('en-US', { 
            year: 'numeric', 
            month: 'long', 
            day: 'numeric',
            hour: '2-digit',
            minute: '2-digit'
          }) %>
        </div>
      <% } else { %>
        <div class="message-meta">
          Posted by <em>Anonymous</em> • Join the club to see authors!
        </div>
      <% } %>

      <% if (user && user.is_admin) { %>
        <form method="POST" action="/messages/<%= message.id %>/delete" style="margin-top: 15px;" onsubmit="return confirm('Are you sure you want to delete this message?');">
          <button type="submit" class="btn btn-danger">🗑️ Delete</button>
        </form>
      <% } %>
    </div>
  <% }) %>
<% } else { %>
  <div style="text-align: center; padding: 60px; color: #999;">
    <h2>No messages yet</h2>
    <p>Be the first to post a message!</p>
  </div>
<% } %>

<%- include('partials/footer') %>