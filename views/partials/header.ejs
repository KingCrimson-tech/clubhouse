<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Clubhouse' %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      padding: 20px;
    }
    .container {
      max-width: 1200px;
      margin: 0 auto;
      background: white;
      border-radius: 10px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.2);
      overflow: hidden;
    }
    nav {
      background: #333;
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    nav a {
      color: white;
      text-decoration: none;
      margin: 0 10px;
      padding: 8px 15px;
      border-radius: 5px;
      transition: background 0.3s;
    }
    nav a:hover { background: #555; }
    .nav-brand { font-size: 1.5rem; font-weight: bold; }
    .content { padding: 2rem; min-height: 400px; }
    .flash {
      padding: 15px;
      margin-bottom: 20px;
      border-radius: 5px;
    }
    .flash.success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
    .flash.error { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
    form { max-width: 500px; }
    .form-group {
      margin-bottom: 20px;
    }
    label {
      display: block;
      margin-bottom: 5px;
      font-weight: 600;
      color: #333;
    }
    input, textarea {
      width: 100%;
      padding: 10px;
      border: 2px solid #ddd;
      border-radius: 5px;
      font-size: 1rem;
      transition: border-color 0.3s;
    }
    input:focus, textarea:focus {
      outline: none;
      border-color: #667eea;
    }
    button, .btn {
      background: #667eea;
      color: white;
      padding: 12px 30px;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      font-size: 1rem;
      text-decoration: none;
      display: inline-block;
      transition: background 0.3s;
    }
    button:hover, .btn:hover {
      background: #5568d3;
    }
    .btn-danger {
      background: #dc3545;
    }
    .btn-danger:hover {
      background: #c82333;
    }
    .message-card {
      background: #f8f9fa;
      padding: 20px;
      margin-bottom: 20px;
      border-radius: 8px;
      border-left: 4px solid #667eea;
    }
    .message-title {
      font-size: 1.3rem;
      color: #333;
      margin-bottom: 10px;
    }
    .message-content {
      color: #555;
      line-height: 1.6;
      margin-bottom: 10px;
    }
    .message-meta {
      font-size: 0.9rem;
      color: #777;
      font-style: italic;
    }
    .badge {
      display: inline-block;
      padding: 5px 10px;
      border-radius: 3px;
      font-size: 0.85rem;
      font-weight: bold;
      margin-left: 10px;
    }
    .badge-member { background: #28a745; color: white; }
    .badge-admin { background: #dc3545; color: white; }
  </style>
</head>
<body>
  <div class="container">
    <nav>
      <a href="/" class="nav-brand">🏛️ Clubhouse</a>
      <div>
        <% if (user) { %>
          <span style="color: white;">Welcome, <%= user.first_name %>
            <% if (user.is_admin) { %>
              <span class="badge badge-admin">ADMIN</span>
            <% } else if (user.is_member) { %>
              <span class="badge badge-member">MEMBER</span>
            <% } %>
          </span>
          <a href="/messages/new">✉️ New Message</a>
          <% if (!user.is_member) { %>
            <a href="/join-club">🔑 Join Club</a>
          <% } %>
          <% if (!user.is_admin) { %>
            <a href="/become-admin">👑 Become Admin</a>
          <% } %>
          <a href="/auth/logout">Logout</a>
        <% } else { %>
          <a href="/login">Login</a>
          <a href="/signup">Sign Up</a>
        <% } %>
      </div>
    </nav>
    <div class="content">
      <% if (success_msg && success_msg.length > 0) { %>
        <div class="flash success"><%= success_msg %></div>
      <% } %>
      <% if (error_msg && error_msg.length > 0) { %>
        <div class="flash error"><%= error_msg %></div>
      <% } %>
      <% if (error && error.length > 0) { %>
        <div class="flash error"><%= error %></div>
      <% } %>